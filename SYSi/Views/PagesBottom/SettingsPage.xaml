<Page
    x:Class="SYSi.Views.PagesBottom.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:helpers="clr-namespace:SYSi.Helpers"
    xmlns:controls="clr-namespace:SYSi.Controls"
    xmlns:local="clr-namespace:SYSi.Views.PagesBottom"
    xmlns:utils="clr-namespace:SYSi.Utils"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="SettingsPage"
    d:DataContext="{d:DesignInstance local:SettingsPage,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d">
    
    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToCollapsedConverter" />
        <helpers:NullOrEmptyToVisibilityConverter x:Key="NullToCollapsedConverter" />
    </Page.Resources>

    <StackPanel>
        <ui:TextBlock
            Margin="0,24,0,8"
            FontTypography="BodyStrong"
            Text="{utils:Localization page_settings_personalization_title}" />

        <controls:FormFieldCard
            Icon="{ui:SymbolIcon Color24}"
            PrimaryText="{utils:Localization page_settings_app_theme_title}"
            DescriptionText="{utils:Localization page_settings_app_theme_summary}">

            <ComboBox
                ItemsSource="{Binding ViewModel.ThemeList}"
                SelectedItem="{Binding ViewModel.SelectedTheme, Mode=TwoWay}"
                DisplayMemberPath="Content"
                MinWidth="100" />
        </controls:FormFieldCard>

        <controls:FormFieldCard
            Icon="{ui:SymbolIcon DesignIdeas24}"
            PrimaryText="{utils:Localization page_settings_display_material_title}"
            DescriptionText="{utils:Localization page_settings_display_material_summary}">

            <ComboBox
                ItemsSource="{Binding ViewModel.MaterialList}"
                SelectedItem="{Binding ViewModel.SelectedMaterial, Mode=TwoWay}"
                DisplayMemberPath="Content"
                MinWidth="100" />
        </controls:FormFieldCard>

        <controls:FormFieldCard
            Icon="{ui:SymbolIcon ExpandUpLeft20}"
            PrimaryText="{utils:Localization page_settings_auto_hide_nav_title}"
            DescriptionText="{utils:Localization page_settings_auto_hide_nav_summary}">

            <ui:ToggleSwitch
                IsChecked="{Binding ViewModel.AutoHideNavigationPanel}" />
        </controls:FormFieldCard>

        <controls:FormFieldCard
            Icon="{ui:SymbolIcon ContentViewGallery28}"
            PrimaryText="{utils:Localization page_settings_corner_radius_title}"
            DescriptionText="{utils:Localization page_settings_corner_radius_summary}">

            <StackPanel Orientation="Horizontal">
                <Slider
                    Width="100"
                    Margin="0 0 6 0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Maximum="20"
                    Minimum="0"
                    Value="{Binding ViewModel.SliderCornerRadius, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:SettingsPage}, Mode=TwoWay}" />

                <TextBlock Text="{Binding ViewModel.SliderCornerRadius, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=local:SettingsPage}, Mode=OneWay}" />
            </StackPanel>
        </controls:FormFieldCard>

        <ui:TextBlock
            Margin="0,24,0,8"
            FontTypography="BodyStrong"
            Text="{utils:Localization page_settings_languageset_title}" />
        
        <controls:FormFieldCard 
            Margin="0,0,0,12"
            Icon="{ui:SymbolIcon LocalLanguage28}"
            PrimaryText="{utils:Localization page_settings_languageset_display_title}"
            DescriptionText="{utils:Localization page_settings_languageset_display_summary}">
            
            <ComboBox
                ItemsSource="{Binding ViewModel.Languages}"
                SelectedItem="{Binding ViewModel.SelectedLanguage, Mode=TwoWay}"
                DisplayMemberPath="NativeName"
                MinWidth="170" />
        </controls:FormFieldCard>

        <ui:TextBlock
            Margin="0,24,0,8"
            FontTypography="BodyStrong"
            Text="{utils:Localization page_settings_update_title}" />

        <ui:Card Margin="0,0,0,4" Padding="16" x:Name="UpdateCard">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Version info row -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                    <ui:TextBlock
                        FontTypography="Body"
                        Text="{utils:Localization page_settings_update_current_version_title}" />
                    <ui:TextBlock
                        Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding ViewModel.AppVersion, Mode=OneWay}" />
                </StackPanel>

                <!-- Check / Cancel button -->
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                    <ui:Button
                        Margin="8,0,0,0"
                        Icon="{ui:SymbolIcon ArrowClockwise24}"
                        Content="{utils:Localization page_settings_update_check_btn}"
                        Command="{Binding ViewModel.CheckForUpdateCommand}"
                        Visibility="{Binding ViewModel.IsChecking, Converter={StaticResource BoolToCollapsedConverter}, ConverterParameter=invert}" />
                    <ui:Button
                        Margin="8,0,0,0"
                        Icon="{ui:SymbolIcon Dismiss24}"
                        Content="{utils:Localization page_settings_update_cancel_btn}"
                        Command="{Binding ViewModel.CancelUpdateCommand}"
                        Visibility="{Binding ViewModel.IsChecking, Converter={StaticResource BoolToCollapsedConverter}}" />
                </StackPanel>

                <!-- Status text row -->
                <ui:TextBlock
                    Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                    Margin="0,8,0,0"
                    Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding ViewModel.UpdateStatusText, Mode=OneWay}"
                    Visibility="{Binding ViewModel.UpdateStatusText, Converter={StaticResource NullToCollapsedConverter}}" />

                <!-- Download progress row -->
                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                      Margin="0,10,0,0"
                      Visibility="{Binding ViewModel.IsDownloading, Converter={StaticResource BoolToCollapsedConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ProgressBar
                        Grid.Column="0"
                        Height="4"
                        VerticalAlignment="Center"
                        Minimum="0" Maximum="100"
                        Value="{Binding ViewModel.DownloadProgress, Mode=OneWay}" />
                    <TextBlock
                        Grid.Column="1"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        Text="{Binding ViewModel.DownloadProgress, StringFormat={}{0:F0}%}" />
                </Grid>
            </Grid>
        </ui:Card>

        <!-- Available update card -->
        <ui:Card
            Margin="0,0,0,12"
            Padding="16"
            Visibility="{Binding ViewModel.IsUpdateAvailable, Converter={StaticResource BoolToCollapsedConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Vertical">
                    <ui:TextBlock
                        FontTypography="BodyStrong"
                        Text="{utils:Localization page_settings_update_new_version_title}" />
                    <ui:TextBlock
                        Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding ViewModel.LatestVersion, Mode=OneWay}" />
                </StackPanel>

                <!-- Download / Install button -->
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:Button
                        Margin="8,0,0,0"
                        Appearance="Primary"
                        Icon="{ui:SymbolIcon ArrowDownload24}"
                        Content="{utils:Localization page_settings_update_download_btn}"
                        Command="{Binding ViewModel.DownloadAndInstallCommand}"
                        Visibility="{Binding ViewModel.IsDownloadReady, Converter={StaticResource BoolToCollapsedConverter}}" />
                    <ui:Button
                        Margin="8,0,0,0"
                        Appearance="Primary"
                        Icon="{ui:SymbolIcon ArrowCircleUp24}"
                        Content="{utils:Localization page_settings_update_install_btn}"
                        Command="{Binding ViewModel.InstallUpdateCommand}"
                        Visibility="{Binding ViewModel.IsReadyToInstall, Converter={StaticResource BoolToCollapsedConverter}}" />
                    <ui:Button
                        Margin="8,0,0,0"
                        Icon="{ui:SymbolIcon Dismiss24}"
                        Content="{utils:Localization page_settings_update_cancel_btn}"
                        Command="{Binding ViewModel.CancelUpdateCommand}" />
                </StackPanel>

                <!-- Release notes -->
                <TextBox
                    Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                    Margin="0,10,0,0"
                    MaxHeight="120"
                    IsReadOnly="True"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto"
                    Text="{Binding ViewModel.ReleaseNotes, Mode=OneWay}"
                    Visibility="{Binding ViewModel.ReleaseNotes, Converter={StaticResource NullToCollapsedConverter}}" />
            </Grid>
        </ui:Card>

        <ui:TextBlock
            Margin="0,24,0,8"
            FontTypography="BodyStrong"
            Text="{utils:Localization page_settings_about_title}" />
        
        <ui:CardExpander 
            ContentPadding="0" 
            Icon="{ui:ImageIcon 'pack://application:,,,/Assets/wpfui-icon-256.png', Width=38, Height=38}"
            Margin="0 0 0 30">
            <ui:CardExpander.Header>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        FontTypography="Body"
                        Text="System Information"
                        TextWrapping="Wrap" />
                    <ui:TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding ViewModel.CopyRight, Mode=OneWay}"
                        TextWrapping="Wrap" />
                    <TextBlock
                        Grid.Row="0"
                        Grid.RowSpan="2"
                        Grid.Column="1"
                        Margin="0,0,16,0"
                        VerticalAlignment="Center"
                        Foreground="{ui:ThemeResource TextFillColorSecondaryBrush}"
                        Text="{Binding ViewModel.AppVersion, Mode=OneWay}" />
                </Grid>
            </ui:CardExpander.Header>
            <StackPanel>
                <ui:Anchor
                    Margin="0"
                    Padding="16"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch"
                    Background="Transparent"
                    BorderThickness="0,1,0,0"
                    CornerRadius="0"
                    NavigateUri="https://www.facebook.com/MaiXuan.HuynhOR/">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{utils:Localization page_settings_contact_us_title}" />
                        <ui:SymbolIcon Grid.Column="1" Symbol="Link24" />
                    </Grid>
                </ui:Anchor>
                <TextBlock Margin="16" Text="{Binding ViewModel.AppVersion, Mode=OneWay}" />
            </StackPanel>
        </ui:CardExpander>
    </StackPanel>
</Page>
