<Page x:Class="SYSi.Views.Pages.OSPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SYSi.Views.Pages"
      xmlns:controls="clr-namespace:SYSi.Controls"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:utils="clr-namespace:SYSi.Utils"
      Title="OSPage"
      d:DataContext="{d:DesignInstance local:OSPage,
                                     IsDesignTimeCreatable=False}"
      d:DesignHeight="450"
      d:DesignWidth="800"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d">

    <Grid Margin="0 0 0 30">
        <StackPanel>
            <!-- Uptime -->
            <ui:CardAction Margin="0 0 0 8"
                           IsChevronVisible="False">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:SymbolIcon Grid.Column="0"
                                   Symbol="Clock24"
                                   FontSize="30"
                                   Width="40"
                                   Height="40" />

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">
                        <TextBlock Text="{utils:Localization uptime_title}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                        <TextBlock Text="{Binding ViewModel.OsInfo.Uptime}"
                                   FontWeight="Bold"
                                   FontSize="18" />
                    </StackPanel>
                </Grid>
            </ui:CardAction>

            <!-- Overview -->
            <ItemsControl>
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Margin="0,0,-8,0">
                            <UniformGrid.Columns>
                                <MultiBinding Converter="{StaticResource WidthToColumnsConverter}">
                                    <!-- ActualWidth của ItemsControl -->
                                    <Binding Path="ActualWidth"
                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}" />

                                    <!-- MinCardWidth -->
                                    <Binding Source="150" />

                                    <!-- MaxColumns -->
                                    <Binding Source="4" />
                                </MultiBinding>
                            </UniformGrid.Columns>
                        </UniformGrid>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.Resources>
                    <Style TargetType="ui:Card"
                           BasedOn="{StaticResource {x:Type ui:Card}}">
                        <Setter Property="Margin"
                                Value="0 0 8 8" />
                    </Style>
                </ItemsControl.Resources>

                <!-- OS Name -->
                <ui:CardAction Margin="0 0 8 8"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization os_name_title}"
                                   FontSize="11"
                                   Margin="0 0 0 4" />

                        <TextBlock Text="{Binding ViewModel.OsInfo.OsName}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0 0 0 4" />

                        <TextBlock Text="{Binding ViewModel.OsInfo.OsArchitecture}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </ui:CardAction>

                <!-- OS Version -->
                <ui:CardAction Margin="0 0 8 8"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization version_title}"
                                   FontSize="11"
                                   Margin="0 0 0 4" />

                        <TextBlock Text="{Binding ViewModel.OsInfo.OsVersion}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0 0 0 4" />

                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="Build" />
                            <Run Text="{Binding ViewModel.OsInfo.BuildNumber}" />
                        </TextBlock>
                    </StackPanel>
                </ui:CardAction>

                <!-- Last Boot -->
                <ui:CardAction Margin="0 0 8 8"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization last_boot_title}"
                                   FontSize="11"
                                   Margin="0 0 0 4" />

                        <TextBlock Text="{Binding ViewModel.OsInfo.LastBootDate}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0 0 0 4" />

                        <TextBlock Text="{Binding ViewModel.OsInfo.LastBootTime}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </ui:CardAction>

                <!-- Install Date -->
                <ui:CardAction Margin="0 0 8 8"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization install_date_title}"
                                   FontSize="11"
                                   Margin="0 0 0 4" />

                        <TextBlock Text="{Binding ViewModel.OsInfo.InstallDate}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="0 0 0 4" />

                        <TextBlock Text="{Binding ViewModel.OsInfo.InstallTime}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </ui:CardAction>
            </ItemsControl>

            <!-- System Info -->
            <ItemsControl Margin="0 0 0 8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Margin="0,0,-8,-8">
                            <UniformGrid.Columns>
                                <MultiBinding Converter="{StaticResource WidthToColumnsConverter}">
                                    <!-- ActualWidth của ItemsControl -->
                                    <Binding Path="ActualWidth"
                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}" />

                                    <!-- MinCardWidth -->
                                    <Binding Source="240" />

                                    <!-- MaxColumns -->
                                    <Binding Source="2" />
                                </MultiBinding>
                            </UniformGrid.Columns>
                        </UniformGrid>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!-- System identity -->
                <ui:CardAction Margin="0 0 8 8"
                               IsChevronVisible="False">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Desktop24"
                                           FontSize="15"
                                           Margin="0 0 8 0"/>
                            <TextBlock Text="{utils:Localization system_identity_title}"
                                       FontWeight="SemiBold"
                                       FontSize="14" />
                        </StackPanel>
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization hostname_title}"
                                          ValueText="{Binding ViewModel.OsInfo.Hostname}"
                                          ValueHorizontalAlign="Right" />
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization username_title}"
                                          ValueText="{Binding ViewModel.OsInfo.Username}"
                                          ValueHorizontalAlign="Right" />
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization arch_title}"
                                          ValueText="{Binding ViewModel.OsInfo.OsArchitecture}"
                                          ValueHorizontalAlign="Right"
                                          IsLast="True" />
                    </StackPanel>
                </ui:CardAction>

                <!-- System status -->
                <ui:CardAction Margin="0 0 8 8"
                               IsChevronVisible="False">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="ShieldCheckmark24"
                                           FontSize="15"
                                           Margin="0 0 8 0" />
                            <TextBlock Text="{utils:Localization system_status_title}"
                                       FontWeight="SemiBold"
                                       FontSize="14" />
                        </StackPanel>
                        
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization windows_update_title}"
                                          ValueHorizontalAlign="Right">
                            <controls:InfoRow.ValueContent>
                                <Border CornerRadius="{DynamicResource ControlCornerRadius}"
                                        Background="{Binding ViewModel.OsInfo.IsUpToDate,
                                            Converter={StaticResource BoolToBadgeBrushConverter}}"
                                        Padding="11,5"
                                        Margin="11,0">
                                    <TextBlock Text="{Binding ViewModel.OsInfo.WindowsUpdateStatus}"
                                               FontSize="12"
                                               Padding="0"
                                               Margin="0"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{Binding ViewModel.OsInfo.IsUpToDate,
                                                        Converter={StaticResource BoolToBadgeBrushConverter},
                                                        ConverterParameter=foreground}" />
                                </Border>
                            </controls:InfoRow.ValueContent>
                        </controls:InfoRow>
                        
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization activation_title}"
                                          ValueHorizontalAlign="Right">
                            <controls:InfoRow.ValueContent>
                                <Border CornerRadius="{DynamicResource ControlCornerRadius}"
                                        Background="{Binding ViewModel.OsInfo.IsActivated,
                                            Converter={StaticResource BoolToBadgeBrushConverter}}"
                                        Padding="11,5"
                                        Margin="11,0">
                                    <TextBlock Text="{Binding ViewModel.OsInfo.ActivationStatus}"
                                               FontSize="12"
                                               Padding="0"
                                               Margin="0"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{Binding ViewModel.OsInfo.IsActivated,
                                                        Converter={StaticResource BoolToBadgeBrushConverter},
                                                        ConverterParameter=foreground}" />
                                </Border>
                            </controls:InfoRow.ValueContent>
                        </controls:InfoRow>
                        
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization edition_title}"
                                          ValueText="{Binding ViewModel.OsInfo.OsEdition}"
                                          ValueHorizontalAlign="Right"
                                          IsLast="True" />
                    </StackPanel>
                </ui:CardAction>
            </ItemsControl>

            <!-- Environment -->
            <ui:CardAction Margin="0 0 0 0"
                           IsChevronVisible="False">
                <StackPanel>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="0,0,0,12">
                        <ui:SymbolIcon Symbol="KeyCommand24"
                                       FontSize="15"
                                       Margin="0 0 8 0" />
                        <TextBlock Text="{utils:Localization environment_title}"
                                   FontWeight="SemiBold"
                                   FontSize="14" />
                    </StackPanel>
                    
                    <controls:InfoRow LabelWidth="100"
                                      LabelText="{utils:Localization system_root_title}"
                                      ValueText="{Binding ViewModel.OsInfo.SystemRoot}"
                                      ValueHorizontalAlign="Right" />
                    <controls:InfoRow LabelWidth="100"
                                      LabelText="{utils:Localization user_profile_title}"
                                      ValueText="{Binding ViewModel.OsInfo.UserProfile}"
                                      ValueHorizontalAlign="Right" />
                    <controls:InfoRow LabelWidth="100"
                                      LabelText="{utils:Localization locale_title}"
                                      ValueText="{Binding ViewModel.OsInfo.Locale}"
                                      ValueHorizontalAlign="Right" />
                    <controls:InfoRow LabelWidth="100"
                                      LabelText="{utils:Localization time_zone_title}"
                                      ValueText="{Binding ViewModel.OsInfo.TimeZone}"
                                      ValueHorizontalAlign="Right"
                                      IsLast="True" />
                </StackPanel>
            </ui:CardAction>
        </StackPanel>
    </Grid>
</Page>
