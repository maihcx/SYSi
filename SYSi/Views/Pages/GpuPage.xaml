<Page x:Class="SYSi.Views.Pages.GpuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SYSi.Views.Pages"
      xmlns:controls="clr-namespace:SYSi.Controls"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:utils="clr-namespace:SYSi.Utils"
      Title="GpuPage"
      d:DataContext="{d:DesignInstance local:GpuPage,
                                     IsDesignTimeCreatable=False}"
      d:DesignHeight="450"
      d:DesignWidth="800"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d">

    <Grid Margin="0 0 0 30">
        <StackPanel>
            <!-- Multi-GPU selector -->
            <ui:CardAction Margin="0 0 0 8"
                           IsChevronVisible="False"
                           Visibility="{Binding ViewModel.NoneGpus, Converter={StaticResource InvertedBoolToVisibilityConverter}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{utils:Localization gpu_multiple_title}"
                               VerticalAlignment="Center"
                               Margin="0 0 12 0" />
                    <ComboBox ItemsSource="{Binding ViewModel.GpuNames}"
                              SelectedItem="{Binding ViewModel.SelectedGpuName, Mode=TwoWay}"
                              MinWidth="300" />
                </StackPanel>
            </ui:CardAction>

            <ui:CardAction Margin="0 0 0 8"
                           IsChevronVisible="False">
                <StackPanel>
                    <Grid Margin="0 0 0 8">
                        <TextBlock Text="{Binding ViewModel.GpuInfo.Name}"
                                   FontWeight="Medium" />
                        <TextBlock HorizontalAlignment="Right"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}">
                            <Run Text="{Binding ViewModel.GpuInfo.UsagePercent, StringFormat={}{0:F1}}" />
                            <Run Text="%" />
                        </TextBlock>
                    </Grid>
                    <ProgressBar Value="{Binding ViewModel.GpuInfo.UsagePercent}"
                                 Maximum="100"
                                 Height="12" />
                </StackPanel>
            </ui:CardAction>

            <!-- Info -->
            <ItemsControl Margin="0 0 0 0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Margin="0 0 -8 -8">
                            <UniformGrid.Columns>
                                <MultiBinding Converter="{StaticResource WidthToColumnsConverter}">
                                    <!-- ActualWidth của ItemsControl -->
                                    <Binding Path="ActualWidth"
                                             RelativeSource="{RelativeSource AncestorType=ItemsControl}" />

                                    <!-- MinCardWidth -->
                                    <Binding Source="250" />

                                    <!-- MaxColumns -->
                                    <Binding Source="2" />
                                </MultiBinding>
                            </UniformGrid.Columns>
                        </UniformGrid>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ui:CardAction Margin="0 0 8 8"
                               IsChevronVisible="False"
                               VerticalAlignment="Stretch"
                               VerticalContentAlignment="Top">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="Info24"
                                           FontSize="15"
                                           Margin="0 0 8 0" />
                            <TextBlock Text="{utils:Localization gen_info_title}"
                                       FontWeight="SemiBold"
                                       FontSize="14" />
                        </StackPanel>
                        
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization gpu_name_title}"
                                          ValueText="{Binding ViewModel.GpuInfo.Name}"
                                          ValueHorizontalAlign="Right" />
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization manu_title}"
                                          ValueText="{Binding ViewModel.GpuInfo.Manufacturer}"
                                          ValueHorizontalAlign="Right" />
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization vram_title}"
                                          ValueText="{Binding ViewModel.GpuInfo.VramText}"
                                          ValueHorizontalAlign="Right" />
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization driver_ver_title}"
                                          ValueText="{Binding ViewModel.GpuInfo.DriverVersion}"
                                          ValueHorizontalAlign="Right" />
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization driver_date_title}"
                                          ValueText="{Binding ViewModel.GpuInfo.DriverDate}"
                                          ValueHorizontalAlign="Right"
                                          IsLast="True" />
                    </StackPanel>
                </ui:CardAction>

                <ui:CardAction Margin="0 0 8 8"
                               IsChevronVisible="False"
                               VerticalAlignment="Stretch"
                               VerticalContentAlignment="Top">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,12">
                            <ui:SymbolIcon Symbol="ShareScreenPerson24"
                                           FontSize="15"
                                           Margin="0 0 8 0" />
                            <TextBlock Text="{utils:Localization display_title}"
                                       FontWeight="SemiBold"
                                       FontSize="14" />
                        </StackPanel>
                        
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization resolution_title}"
                                          ValueText="{Binding ViewModel.GpuInfo.Resolution}"
                                          ValueHorizontalAlign="Right" />
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization refresh_rate_title}"
                                          ValueText="{Binding ViewModel.GpuInfo.RefreshRate}"
                                          ValueHorizontalAlign="Right" />
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization color_depth_title}"
                                          ValueText="{Binding ViewModel.GpuInfo.BitsPerPixel}"
                                          ValueHorizontalAlign="Right" />
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization arch_title}"
                                          ValueText="{Binding ViewModel.GpuInfo.VideoArchitecture}"
                                          ValueHorizontalAlign="Right" />
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization mem_type_title}"
                                          ValueText="{Binding ViewModel.GpuInfo.VideoMemoryType}"
                                          ValueHorizontalAlign="Right" />
                        <controls:InfoRow LabelWidth="100"
                                          LabelText="{utils:Localization pnp_label}"
                                          ValueText="{Binding ViewModel.GpuInfo.PnpDeviceId}"
                                          ValueHorizontalAlign="Right"
                                          IsLast="True" />
                    </StackPanel>
                </ui:CardAction>
            </ItemsControl>
        </StackPanel>
    </Grid>
</Page>
