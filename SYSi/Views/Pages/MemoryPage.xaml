<Page x:Class="SYSi.Views.Pages.MemoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SYSi.Views.Pages"
      xmlns:controls="clr-namespace:SYSi.Controls"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:utils="clr-namespace:SYSi.Utils"
      Title="MemoryPage"
      d:DataContext="{d:DesignInstance local:MemoryPage,
                                     IsDesignTimeCreatable=False}"
      d:DesignHeight="450"
      d:DesignWidth="800"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d">

    <Grid Margin="0 0 0 30">
        <StackPanel>

            <!-- Summary Row: Total / Used / Available -->
            <Grid Margin="0 0 0 8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ui:CardAction Grid.Column="0"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization memory_total_title}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ViewModel.RamInfo.TotalText}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Grid.Column="2"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization memory_used_title}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ViewModel.RamInfo.UsedText}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Grid.Column="4"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization memory_available_title}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ViewModel.RamInfo.AvailableText}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </ui:CardAction>
            </Grid>

            <!-- Summary Row 2: Type / Speed / Channel / Slots -->
            <Grid Margin="0 0 0 8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ui:CardAction Grid.Column="0"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization memory_type_title}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ViewModel.RamInfo.MemoryType}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Grid.Column="2"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization memory_speed_title}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ViewModel.RamInfo.SpeedText}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Grid.Column="4"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization memory_channel_title}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ViewModel.RamInfo.ChannelMode}"
                                   FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Grid.Column="6"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization memory_slots_used_title}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis">
                            <Run Text="{Binding ViewModel.RamInfo.PopulatedSlots, Mode=OneWay}" />
                            <Run Text="/" />
                            <Run Text="{Binding ViewModel.RamInfo.TotalSlots, Mode=OneWay}" />
                        </TextBlock>
                    </StackPanel>
                </ui:CardAction>
            </Grid>

            <!-- Usage bar -->
            <ui:CardAction Margin="0,0,0,20"
                           IsChevronVisible="False">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{utils:Localization memory_used_title}"
                                   FontWeight="Medium" />
                        <TextBlock HorizontalAlignment="Right"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}">
                            <Run Text="{Binding ViewModel.RamInfo.UsagePercent, StringFormat={}{0:F1}}" />
                            <Run Text="%" />
                        </TextBlock>
                    </Grid>
                    <ProgressBar Value="{Binding ViewModel.RamInfo.UsagePercent}"
                                 Maximum="100"
                                 Height="12" />
                </StackPanel>
            </ui:CardAction>

            <!-- Slots heading -->
            <TextBlock Text="{utils:Localization memory_slots_title}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12" />

            <ListBox ItemsSource="{Binding ViewModel.RamInfo.Slots}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.CanContentScroll="True">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment"
                                Value="Stretch" />
                        <Setter Property="Padding"
                                Value="0" />
                        <Setter Property="Margin"
                                Value="0" />
                        <Setter Property="Focusable"
                                Value="False" />
                        <Setter Property="FocusVisualStyle"
                                Value="{x:Null}" />

                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ui:CardAction Margin="0,0,0,8"
                                       IsChevronVisible="False">
                            <StackPanel>
                                <!-- Slot header -->
                                <ui:Card Margin="-4,-4,-4,8"
                                         Padding="8 4"
                                         Background="{DynamicResource SystemFillColorNeutralBackgroundBrush}">
                                    <Grid VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <ui:SymbolIcon Grid.Column="0"
                                                       Symbol="Memory16"
                                                       FontSize="20"
                                                       Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding BankLabel}"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   VerticalAlignment="Center"
                                                   Margin="0" />
                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding CapacityText}"
                                                   FontSize="13"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" />

                                        <Border Grid.Column="5"
                                                Padding="8 2"
                                                Margin="0 4"
                                                CornerRadius="4"
                                                Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}"
                                                Visibility="{Binding Rank, Converter={StaticResource ZeroToCollapsedConverter}}">
                                            <TextBlock FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}">
                                                    <Run Text="Rank " />
                                                    <Run Text="{Binding Rank}" />
                                            </TextBlock>
                                        </Border>
                                    </Grid>
                                </ui:Card>

                                <!-- Row 1: Type / Speed (rated) / Manufacturer -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{utils:Localization memory_type_title}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding MemoryType}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{utils:Localization memory_speed_rated_title}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding SpeedMHz}" /><Run Text=" MHz" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{utils:Localization manu_title}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding Manufacturer}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>

                                <!-- Row 2: Form Factor / Configured Speed / Data Width -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{utils:Localization memory_form_factor_title}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding FormFactor}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{utils:Localization memory_speed_configured_title}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding ConfiguredSpeedMHz}" /><Run Text=" MHz" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{utils:Localization memory_data_width_title}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding DataWidth}" /><Run Text=" bit" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 3: Voltage (configured / min / max) -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{utils:Localization memory_voltage_title}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding ConfiguredVoltage, Converter={StaticResource MvToVoltConverter}}" /><Run Text=" V" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{utils:Localization memory_min_voltage_title}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding MinVoltage, Converter={StaticResource MvToVoltConverter}}" /><Run Text=" V" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{utils:Localization memory_max_voltage_title}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis">
                                            <Run Text="{Binding MaxVoltage, Converter={StaticResource MvToVoltConverter}}" /><Run Text=" V" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>

                                <!-- Row 4: Part Number / Serial Number -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{utils:Localization memory_part_number_title}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding PartNumber}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="{utils:Localization memory_serial_number_title}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding SerialNumber}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Grid>

                            </StackPanel>
                        </ui:CardAction>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </Grid>
</Page>