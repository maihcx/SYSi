<Page x:Class="SYSi.Views.Pages.MemoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:SYSi.Views.Pages"
      xmlns:controls="clr-namespace:SYSi.Controls"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:utils="clr-namespace:SYSi.Utils"
      Title="MemoryPage"
      d:DataContext="{d:DesignInstance local:MemoryPage,
                                     IsDesignTimeCreatable=False}"
      d:DesignHeight="450"
      d:DesignWidth="800"
      ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
      ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      Foreground="{DynamicResource TextFillColorPrimaryBrush}"
      mc:Ignorable="d">

    <Grid Margin="0 0 0 30">
        <StackPanel>
            <!-- Summary Row -->
            <Grid Margin="0 0 0 8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ui:CardAction Grid.Column="0"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization memory_total_title}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ViewModel.RamInfo.TotalText}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Grid.Column="2"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization memory_used_title}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ViewModel.RamInfo.UsedText}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </StackPanel>
                </ui:CardAction>
                <ui:CardAction Grid.Column="4"
                               IsChevronVisible="False">
                    <StackPanel>
                        <TextBlock Text="{utils:Localization memory_available_title}"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding ViewModel.RamInfo.AvailableText}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                    </StackPanel>
                </ui:CardAction>
            </Grid>

            <!-- Usage bar -->
            <ui:CardAction Margin="0,0,0,20"
                           IsChevronVisible="False">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{utils:Localization memory_used_title}"
                                   FontWeight="Medium" />
                        <TextBlock HorizontalAlignment="Right"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}">
                    <Run Text="{Binding ViewModel.RamInfo.UsagePercent, StringFormat={}{0:F1}}" />
                    <Run Text="%" />
                        </TextBlock>
                    </Grid>
                    <ProgressBar Value="{Binding ViewModel.RamInfo.UsagePercent}"
                                 Maximum="100"
                                 Height="12" />
                </StackPanel>
            </ui:CardAction>

            <!-- Slots -->
            <TextBlock Text="{utils:Localization memory_slots_title}"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Margin="0,0,0,12" />

            <ItemsControl ItemsSource="{Binding ViewModel.RamInfo.Slots}" Margin="0 0 0 -8">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardAction Margin="0,0,0,8"
                                       IsChevronVisible="False">
                            <StackPanel>
                                <!-- Slot header -->
                                <StackPanel Orientation="Horizontal"
                                            Margin="0,0,0,12">
                                    <ui:SymbolIcon Symbol="Memory16"
                                                   FontSize="20"
                                                   Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}" />
                                    <TextBlock Text="{Binding BankLabel}"
                                               FontWeight="Bold"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               Margin="8,0,12,0" />
                                    <TextBlock Text="{Binding CapacityText}"
                                               FontSize="13"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Row 1 -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Type"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding MemoryType}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Speed"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock FontWeight="SemiBold">
                                    <Run Text="{Binding SpeedMHz}" /><Run Text=" MHz" />
                                        </TextBlock>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Manufacturer"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding Manufacturer}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                </Grid>

                                <!-- Row 2 -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Form Factor"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding FormFactor}"
                                                   FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Part Number"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="{Binding PartNumber}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Data Width"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                        <TextBlock FontWeight="SemiBold">
                                    <Run Text="{Binding DataWidth}" /><Run Text=" bit" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </ui:CardAction>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Grid>
</Page>
