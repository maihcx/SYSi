<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:SYSi.Controls"
                    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">

    <Style TargetType="{x:Type controls:ReferralCard}">
        <Setter Property="Focusable"
                Value="False" />
        <Setter Property="SnapsToDevicePixels"
                Value="True" />
        <Setter Property="OverridesDefaultStyle"
                Value="True" />
        <Setter Property="Margin"
                Value="4,4,4,14" />
        <Setter Property="Border.CornerRadius"
                Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ReferralCard}">
                    <Border CornerRadius="{TemplateBinding Border.CornerRadius}">
                        <Border.Background>
                            <ImageBrush ImageSource="{Binding ImageSource, RelativeSource={RelativeSource TemplatedParent}}"
                                        RenderOptions.BitmapScalingMode="HighQuality"
                                        Stretch="UniformToFill" />
                        </Border.Background>
                        <Border CornerRadius="{TemplateBinding Border.CornerRadius}">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5"
                                                     EndPoint="1,0.5">
                                    <GradientStop Offset="0.25"
                                                  Color="#B312788A" />
                                    <GradientStop Offset="0.50"
                                                  Color="#B0006587" />
                                    <GradientStop Offset="0.75"
                                                  Color="#B0004478" />
                                    <GradientStop Offset="1.00"
                                                  Color="#B0002B57" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <StackPanel Margin="48 30 0 10"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Background="Transparent">
                                    <ui:TextBlock FontTypography="Title"
                                                  Foreground="#FFFFFF"
                                                  Text="{TemplateBinding Title}" />
                                    <ui:TextBlock FontTypography="Subtitle"
                                                  Foreground="#B7FFFFFF"
                                                  Text="{TemplateBinding Subtitle}" />
                                    <ui:TextBlock FontTypography="BodyStrong"
                                                  Foreground="#B7FFFFFF"
                                                  Text="{TemplateBinding Description}" />
                                </StackPanel>
                                <ContentPresenter Content="{TemplateBinding FooterContent}"
                                                  Margin="25 15" />
                                <ui:TextBlock Margin="0 0 12 12"
                                              HorizontalAlignment="Right"
                                              VerticalAlignment="Bottom"
                                              FontTypography="Caption"
                                              Foreground="#57FFFFFF"
                                              Text="{TemplateBinding FooterText}" />
                            </StackPanel>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>