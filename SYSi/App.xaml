<Application x:Class="SYSi.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:helpers="clr-namespace:SYSi.Helpers"
             DispatcherUnhandledException="OnDispatcherUnhandledException"
             Exit="OnExit"
             Startup="OnStartup">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />

                <ResourceDictionary Source="Controls/ReferralCard.xaml" />
                <ResourceDictionary Source="Controls/GalleryNavigationPresenter.xaml" />
                <ResourceDictionary Source="Controls/FormFieldCard.xaml" />
                <ResourceDictionary Source="Controls/InfoRow.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <helpers:BoolToGreenRedBrush x:Key="BoolToGreenRedBrush" />
            <helpers:BoolToStatusText x:Key="BoolToStatusText" />
            <helpers:StringToColorConverter x:Key="StringToColorConverter" />
            <helpers:BooleanToString x:Key="BooleanToString" />
            <helpers:WidthToColumnsConverter x:Key="WidthToColumnsConverter" />
            <helpers:InvertedBoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
