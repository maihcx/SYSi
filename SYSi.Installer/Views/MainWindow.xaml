<ui:FluentWindow
    x:Class="SYSi.Installer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:vm="clr-namespace:SYSi.Installer.ViewModels"
    xmlns:local="clr-namespace:SYSi.Installer.Utils"
    Title="SYSi Installer"
    Width="850" Height="600"
    MinWidth="850" MinHeight="600"
    WindowStartupLocation="CenterScreen"
    ExtendsContentIntoTitleBar="True"
    WindowBackdropType="Tabbed">

    <ui:FluentWindow.Resources>
        <!-- Step indicator style -->
        <Style x:Key="StepDot" TargetType="Ellipse">
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
            <Setter Property="Fill" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
        <Style x:Key="StepDotActive" TargetType="Ellipse" BasedOn="{StaticResource StepDot}">
            <Setter Property="Fill" Value="{DynamicResource SystemAccentColorPrimaryBrush}"/>
            <Setter Property="Width" Value="10"/>
            <Setter Property="Height" Value="10"/>
        </Style>
        <Style x:Key="StepDotDone" TargetType="Ellipse" BasedOn="{StaticResource StepDot}">
            <Setter Property="Fill" Value="{DynamicResource SystemAccentColorSecondaryBrush}"/>
        </Style>

        <!-- Sidebar label style -->
        <Style x:Key="SideLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorTertiaryBrush}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8,0,0,0"/>
        </Style>
        <Style x:Key="SideLabelActive" TargetType="TextBlock" BasedOn="{StaticResource SideLabel}">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </ui:FluentWindow.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ============================================================
             LEFT SIDEBAR
        ============================================================ -->
        <Border Grid.Column="0"
                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="24,80,16,24">
                <!-- App Logo / Title -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,32">
                    <Image Source="/Assets/app-256.png" Width="36" Height="36"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="System Info" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Setup" FontSize="11"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Step list - only visible in install flow -->
                <StackPanel x:Name="SideSteps"
                            Visibility="{Binding IsUninstallMode,
                                Converter={StaticResource BoolToVisibilityInverted},
                                FallbackValue=Visible}">

                    <!-- Step 1: Welcome -->
                    <StackPanel Orientation="Horizontal" Margin="0,6">
                        <Ellipse Style="{Binding StepIndex, Converter={StaticResource StepDotConverter}, ConverterParameter=1}"/>
                        <TextBlock Text="{local:LocalizationExtension welcome_title}"
                                   Style="{Binding StepIndex, Converter={StaticResource SideLabelConverter}, ConverterParameter=1}"/>
                    </StackPanel>

                    <!-- Step 2: License -->
                    <StackPanel Orientation="Horizontal" Margin="0,6">
                        <Ellipse Style="{Binding StepIndex, Converter={StaticResource StepDotConverter}, ConverterParameter=2}"/>
                        <TextBlock Text="{local:LocalizationExtension license_title}"
                                   Style="{Binding StepIndex, Converter={StaticResource SideLabelConverter}, ConverterParameter=2}"/>
                    </StackPanel>

                    <!-- Step 3: Path -->
                    <StackPanel Orientation="Horizontal" Margin="0,6">
                        <Ellipse Style="{Binding StepIndex, Converter={StaticResource StepDotConverter}, ConverterParameter=3}"/>
                        <TextBlock Text="{local:LocalizationExtension path_title}"
                                   Style="{Binding StepIndex, Converter={StaticResource SideLabelConverter}, ConverterParameter=3}"/>
                    </StackPanel>

                    <!-- Step 4: Options -->
                    <StackPanel Orientation="Horizontal" Margin="0,6">
                        <Ellipse Style="{Binding StepIndex, Converter={StaticResource StepDotConverter}, ConverterParameter=4}"/>
                        <TextBlock Text="{local:LocalizationExtension options_title}"
                                   Style="{Binding StepIndex, Converter={StaticResource SideLabelConverter}, ConverterParameter=4}"/>
                    </StackPanel>

                    <!-- Step 5: Install -->
                    <StackPanel Orientation="Horizontal" Margin="0,6">
                        <Ellipse Style="{Binding StepIndex, Converter={StaticResource StepDotConverter}, ConverterParameter=5}"/>
                        <TextBlock Text="{local:LocalizationExtension installing_title}"
                                   Style="{Binding StepIndex, Converter={StaticResource SideLabelConverter}, ConverterParameter=5}"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ============================================================
             RIGHT CONTENT AREA  (ContentControl switches pages)
        ============================================================ -->
        <ContentControl Grid.Column="1"
                        Content="{Binding}"
                        Margin="0,32,0,0">
            <ContentControl.Resources>

                
                <!-- PAGE: Language Selection                            -->
                
                <DataTemplate x:Key="LanguageTpl">
                    <Grid Margin="40,32">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:LocalizationExtension lang_select_title}"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{local:LocalizationExtension lang_select_subtitle}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,32"/>

                            <ListBox ItemsSource="{Binding Languages}"
                                     SelectedItem="{Binding SelectedLanguage}"
                                     Width="260"
                                     HorizontalAlignment="Left"
                                     BorderThickness="1"
                                     BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                     Background="{DynamicResource ControlFillColorDefaultBrush}"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     Margin="0,0,0,32">

                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Margin"
                                                Value="4" />
                                        <Setter Property="Padding"
                                                Value="0" />
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Border"
                                                            CornerRadius="8"
                                                            Background="{TemplateBinding Background}"
                                                            Padding="4">
                                                        <ContentPresenter />
                                                    </Border>

                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver"
                                                                 Value="True">
                                                            <Setter TargetName="Border"
                                                                    Property="Background"
                                                                    Value="{DynamicResource ControlFillColorSecondaryBrush}" />
                                                        </Trigger>

                                                        <Trigger Property="IsSelected"
                                                                 Value="True">
                                                            <Setter TargetName="Border"
                                                                    Property="Background"
                                                                    Value="{DynamicResource AccentFillColorDefaultBrush}" />
                                                            <Setter Property="Foreground"
                                                                    Value="{DynamicResource ListBoxItemSelectedForegroundThemeBrush}" />
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>

                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="8,6">
                                            <TextBlock Text="{Binding NativeName}"
                                                       FontSize="15"
                                                       VerticalAlignment="Center" />

                                            <TextBlock Text=" - "
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       VerticalAlignment="Center" />

                                            <TextBlock Text="{Binding EnglishName}"
                                                       FontSize="13"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>

                            </ListBox>

                            <ui:Button
                                Content="{local:LocalizationExtension lang_select_next}"
                                Command="{Binding SelectLanguageCmd}"
                                Appearance="Primary"
                                Icon="{ui:SymbolIcon ChevronRight24}"
                                HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>

                
                <!-- PAGE: Welcome                                       -->
                
                <DataTemplate x:Key="WelcomeTpl">
                    <Grid Margin="40,32">
                        <StackPanel>
                            <TextBlock Text="{local:LocalizationExtension welcome_summary}"
                                       FontSize="26" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,6"/>
                            <TextBlock FontSize="13"
                                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                       Margin="0,0,0,24">
                                        <Run Text="{local:LocalizationExtension version_title}" /><Run Text=":"/>
                                        <Run Text="{Binding AppVersion}" />
                            </TextBlock>
                            <TextBlock Text="{local:LocalizationExtension welcome_description}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="22"
                                       Margin="0,0,0,40"/>
                        </StackPanel>
                        <ui:Button
                            Content="{local:LocalizationExtension welcome_next}"
                            Command="{Binding NextFromWelcomeCmd}"
                            Appearance="Primary"
                            Icon="{ui:SymbolIcon ChevronRight24}"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,0"/>
                    </Grid>
                </DataTemplate>

                
                <!-- PAGE: License                                       -->
                
                <DataTemplate x:Key="LicenseTpl">
                    <Grid Margin="40,32">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{local:LocalizationExtension license_title}"
                                   FontSize="22" FontWeight="Bold"
                                   Margin="0,0,0,16"/>

                        <Border Grid.Row="1"
                                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="6"
                                Margin="0,0,0,12">
                            <ScrollViewer Padding="12">
                                <TextBlock Text="{Binding LicenseText}"
                                           FontFamily="Consolas" FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                            </ScrollViewer>
                        </Border>

                        <CheckBox Grid.Row="2"
                                  Content="{local:LocalizationExtension license_accept}"
                                  IsChecked="{Binding LicenseAccepted}"
                                  Margin="0,0,0,16"/>

                        <StackPanel Grid.Row="3" Orientation="Horizontal"
                                    HorizontalAlignment="Right">
                            <ui:Button Content="{local:LocalizationExtension license_back}"
                                       Command="{Binding BackFromLicenseCmd}"
                                       Margin="0,0,8,0"/>
                            <ui:Button Content="{local:LocalizationExtension license_next}"
                                       Command="{Binding NextFromLicenseCmd}"
                                       Appearance="Primary"
                                       Icon="{ui:SymbolIcon ChevronRight24}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>

                
                <!-- PAGE: Install Path                                  -->
                
                <DataTemplate x:Key="PathTpl">
                    <Grid Margin="40,32">
                        <StackPanel>
                            <TextBlock Text="{local:LocalizationExtension path_title}"
                                       FontSize="22" FontWeight="Bold"
                                       Margin="0,0,0,24"/>

                            <TextBlock Text="{local:LocalizationExtension path_label}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,0,8"/>

                            <Grid Margin="0,0,0,24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ui:TextBox Grid.Column="0"
                                            Text="{Binding InstallPath, UpdateSourceTrigger=PropertyChanged}"
                                            FontSize="13"
                                            Margin="0,0,8,0"/>
                                <ui:Button Grid.Column="1"
                                           Content="{local:LocalizationExtension path_browse}"
                                           Command="{Binding BrowseFolderCmd}"/>
                            </Grid>

                            <TextBlock Text="{local:LocalizationExtension path_required_space}"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                       Margin="0,0,0,32"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,0,0">
                            <ui:Button Content="{local:LocalizationExtension path_back}"
                                       Command="{Binding BackFromPathCmd}"
                                       Margin="0,0,8,0"/>
                            <ui:Button Content="{local:LocalizationExtension path_next}"
                                       Command="{Binding NextFromPathCmd}"
                                       Appearance="Primary"
                                       Icon="{ui:SymbolIcon ChevronRight24}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>

                
                <!-- PAGE: Options                                       -->
                
                <DataTemplate x:Key="OptionsTpl">
                    <Grid Margin="40,32">
                        <StackPanel>
                            <TextBlock Text="{local:LocalizationExtension options_title}"
                                       FontSize="22" FontWeight="Bold"
                                       Margin="0,0,0,32"/>

                            <CheckBox Content="{local:LocalizationExtension options_shortcut_desktop}"
                                      IsChecked="{Binding DesktopShortcut}"
                                      FontSize="14" Margin="0,0,0,12"/>
                            <CheckBox Content="{local:LocalizationExtension options_shortcut_startmenu}"
                                      IsChecked="{Binding StartMenuShortcut}"
                                      FontSize="14"
                                      Margin="0,0,0,12" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,0,0">
                            <ui:Button Content="{local:LocalizationExtension options_back}"
                                       Command="{Binding BackFromOptionsCmd}"
                                       Margin="0,0,8,0"/>
                            <ui:Button Content="{local:LocalizationExtension options_next}"
                                       Command="{Binding NextFromOptionsCmd}"
                                       Appearance="Primary"
                                       Icon="{ui:SymbolIcon ArrowDownload24}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>

                
                <!-- PAGE: Installing                                    -->
                
                <DataTemplate x:Key="InstallingTpl">
                    <Grid Margin="40,32">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:LocalizationExtension installing_title}"
                                       FontSize="22" FontWeight="Bold"
                                       Margin="0,0,0,32"/>

                            <ProgressBar Value="{Binding Progress}"
                                            Minimum="0" Maximum="100"
                                            Height="8"
                                            Margin="0,0,0,16"
                                            IsIndeterminate="False"/>

                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>

                
                <!-- PAGE: Finish                                        -->
                
                <DataTemplate x:Key="FinishTpl">
                    <Grid Margin="40,32">
                        <StackPanel VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="CheckmarkCircle48"
                                           FontSize="56"
                                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                           Margin="0,0,0,20"/>
                            <TextBlock Text="{local:LocalizationExtension finish_title}"
                                       FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{local:LocalizationExtension finish_description}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,0,0,32"/>
                            <CheckBox Content="{local:LocalizationExtension finish_launch}"
                                      IsChecked="{Binding LaunchAfterInstall}"
                                      HorizontalAlignment="Center"
                                      FontSize="14"
                                      Margin="0,0,0,24"/>
                            <ui:Button Content="{local:LocalizationExtension finish_close}"
                                       Command="{Binding FinishCmd}"
                                       Appearance="Primary"
                                       HorizontalAlignment="Center"
                                       Icon="{ui:SymbolIcon Checkmark24}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>

                
                <!-- PAGE: Error                                         -->
                
                <DataTemplate x:Key="ErrorTpl">
                    <Grid Margin="40,32">
                        <StackPanel VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="DismissCircle48"
                                           FontSize="56"
                                           Foreground="OrangeRed"
                                           Margin="0,0,0,20"/>
                            <TextBlock Text="{local:LocalizationExtension error_title}"
                                       FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{local:LocalizationExtension error_description}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding ErrorDetail}"
                                       FontSize="12"
                                       FontFamily="Consolas"
                                       Foreground="OrangeRed"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,0,0,32"/>
                            <Button Content="{local:LocalizationExtension error_close}"
                                    Click="CloseButton_Click"
                                    HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>

                
                <!-- PAGE: Uninstall Confirm                             -->
                
                <DataTemplate x:Key="UninstallConfirmTpl">
                    <Grid Margin="40,32">
                        <StackPanel VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="Delete48"
                                           FontSize="56"
                                           Foreground="OrangeRed"
                                           Margin="0,0,0,20"/>
                            <TextBlock Text="{local:LocalizationExtension uninstall_title}"
                                       FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="{local:LocalizationExtension uninstall_description}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,0,0,32"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <ui:Button Content="{local:LocalizationExtension uninstall_cancel}"
                                           Command="{Binding UninstallCancelCmd}"
                                           Margin="0,0,12,0"/>
                                <ui:Button Content="{local:LocalizationExtension uninstall_confirm}"
                                           Command="{Binding UninstallConfirmCmd}"
                                           Appearance="Danger"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </DataTemplate>

                
                <!-- PAGE: Uninstalling                                  -->
                
                <DataTemplate x:Key="UninstallingTpl">
                    <Grid Margin="40,32">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{local:LocalizationExtension uninstall_progress_title}"
                                       FontSize="22" FontWeight="Bold"
                                       Margin="0,0,0,32"/>
                            <ProgressBar Value="{Binding Progress}"
                                            Minimum="0" Maximum="100"
                                            Height="8"
                                            Margin="0,0,0,16"/>
                            <TextBlock Text="{Binding StatusText}"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>

                
                <!-- PAGE: Uninstall Done                                -->
                
                <DataTemplate x:Key="UninstallDoneTpl">
                    <Grid Margin="40,32">
                        <StackPanel VerticalAlignment="Center">
                            <ui:SymbolIcon Symbol="CheckmarkCircle48"
                                           FontSize="56"
                                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                           Margin="0,0,0,20"/>
                            <TextBlock Text="{local:LocalizationExtension uninstall_done_title}"
                                       FontSize="24" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{local:LocalizationExtension uninstall_done_description}"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"
                                       TextAlignment="Center"
                                       Margin="0,0,0,32"/>
                            <ui:Button Content="{local:LocalizationExtension uninstall_close}"
                                       Command="{Binding UninstallDoneCmd}"
                                       Appearance="Primary"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </DataTemplate>

            </ContentControl.Resources>

            <!-- Step -> template selector via triggers in code-behind -->
            <ContentControl.Style>
                <Style TargetType="ContentControl">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Step}" Value="Language">
                            <Setter Property="ContentTemplate" Value="{StaticResource LanguageTpl}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Step}" Value="Welcome">
                            <Setter Property="ContentTemplate" Value="{StaticResource WelcomeTpl}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Step}" Value="License">
                            <Setter Property="ContentTemplate" Value="{StaticResource LicenseTpl}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Step}" Value="InstallPath">
                            <Setter Property="ContentTemplate" Value="{StaticResource PathTpl}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Step}" Value="Options">
                            <Setter Property="ContentTemplate" Value="{StaticResource OptionsTpl}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Step}" Value="Installing">
                            <Setter Property="ContentTemplate" Value="{StaticResource InstallingTpl}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Step}" Value="Finish">
                            <Setter Property="ContentTemplate" Value="{StaticResource FinishTpl}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Step}" Value="Error">
                            <Setter Property="ContentTemplate" Value="{StaticResource ErrorTpl}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Step}" Value="UninstallConfirm">
                            <Setter Property="ContentTemplate" Value="{StaticResource UninstallConfirmTpl}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Step}" Value="Uninstalling">
                            <Setter Property="ContentTemplate" Value="{StaticResource UninstallingTpl}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Step}" Value="UninstallDone">
                            <Setter Property="ContentTemplate" Value="{StaticResource UninstallDoneTpl}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ContentControl.Style>
        </ContentControl>

        <!-- Title bar overlay (drag area) -->
        <ui:TitleBar Title="" Grid.ColumnSpan="2"
                     ShowMinimize="True" ShowMaximize="False"
                     VerticalAlignment="Top"/>
    </Grid>
</ui:FluentWindow>
