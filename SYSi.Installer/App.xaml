<Application x:Class="SYSi.Installer.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:conv="clr-namespace:SYSi.Installer.Utils">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- Converters -->
            <conv:StepDotStyleConverter    x:Key="StepDotConverter"/>
            <conv:SideLabelStyleConverter  x:Key="SideLabelConverter"/>
            <conv:BoolToVisibilityConverter         x:Key="BoolToVisibility"/>
            <conv:BoolToVisibilityInvertedConverter x:Key="BoolToVisibilityInverted"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
